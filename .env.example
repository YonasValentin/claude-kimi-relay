# Optional override when `kimi` is not on PATH.
KIMI_CLI_PATH=kimi

# Optional persistent state directory. Claude Code supplies CLAUDE_PLUGIN_DATA automatically.
CLAUDE_KIMI_RELAY_DATA_DIR=

# Default task timeout in milliseconds.
CLAUDE_KIMI_RELAY_TIMEOUT_MS=1800000

# Maximum copied file size when creating an isolated workspace.
CLAUDE_KIMI_RELAY_MAX_FILE_BYTES=5242880
CLAUDE_KIMI_RELAY_MAX_RESULT_BYTES=10485760
CLAUDE_KIMI_RELAY_MAX_WORKSPACE_BYTES=2147483648
